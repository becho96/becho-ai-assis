# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_AUTHORIZED_USER_ID=your_telegram_user_id_here
TELEGRAM_SESSION_STRING=

# Notion Configuration
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_KNOWLEDGE_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TASKS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DAILY_LOG_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Yandex Calendar Configuration
YANDEX_OAUTH_TOKEN=your_yandex_oauth_token_here
YANDEX_CALENDAR_URL=https://caldav.yandex.ru

# Perplexity Configuration
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# n8n Configuration
N8N_USER=admin
N8N_PASSWORD=your_secure_password_here
WEBHOOK_URL=http://localhost:5678

# Database Paths
DB_PATH=./data/assistant.db
CHROMA_PATH=./data/chroma

# Claude Configuration (optional - uses system default if not set)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Proxy Configuration (optional)
# Use this to route all outbound traffic through an external proxy server.
# Required if you are running the assistant from a region where Anthropic,
# Perplexity, Notion, or Telegram are restricted.
#
# Supported formats:
#   http://host:port
#   http://user:password@host:port
#   https://host:port
#
# For SOCKS5: set up a local HTTP-to-SOCKS5 bridge (e.g. privoxy, dante)
# and point HTTPS_PROXY at the local HTTP listener.
#
# HTTPS_PROXY takes precedence over HTTP_PROXY which takes precedence over ALL_PROXY.
#
# HTTPS_PROXY=http://user:password@your-proxy-host:3128
# HTTP_PROXY=http://user:password@your-proxy-host:3128
